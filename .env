# ══════════════════════════════════════════════════════════════════════════
# hirepath — .env
# ══════════════════════════════════════════════════════════════════════════
# Keep this file out of version control. It is already in .gitignore.
# Every variable here is read by resume_ai/settings.py via django-environ.
# ══════════════════════════════════════════════════════════════════════════


# ── Django core ────────────────────────────────────────────────────────────

# Secret key used for cryptographic signing (sessions, CSRF, password reset
# tokens). NEVER share or commit this value.
# Generate a fresh one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-4kg*6xt&an%pcoufof!m5c@8qeu1hnkx9)39p@&92$^fhsg5-0

# Set to False in staging / production.
DEBUG=True

# Comma-separated. Add your domain or server IP when deploying.
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0


# ── Email ──────────────────────────────────────────────────────────────────
#
# EMAIL_BACKEND_TYPE controls which backend Django uses:
#
#   console  →  prints emails to the terminal (current dev default, no setup needed)
#   smtp     →  sends real emails via SMTP (switch to this for production)
#   file     →  writes .eml files to disk (useful for automated tests)
#
EMAIL_BACKEND_TYPE=console

# ── SMTP settings — only active when EMAIL_BACKEND_TYPE=smtp ─────────────
# Uncomment and fill in when you are ready to send real emails.
#
# Gmail example (requires a 16-char App Password, not your account password):
#   https://myaccount.google.com/apppasswords
#
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=abcd efgh ijkl mnop
# EMAIL_TIMEOUT=10

# ── File backend — only active when EMAIL_BACKEND_TYPE=file ──────────────
# EMAIL_FILE_PATH=/tmp/hirepath-emails

# ── Sender identity ───────────────────────────────────────────────────────
# The From: address on all outgoing emails (password reset, shortlist,
# status change notifications). Format: "Display Name <address@domain>"
DEFAULT_FROM_EMAIL=hirepath <noreply@hirepath.local>

# Address for Django's internal server-error emails (sent to ADMINS list).
# Defaults to DEFAULT_FROM_EMAIL if left unset — safe to leave commented.
# SERVER_EMAIL=hirepath <server@hirepath.local>


# ── Password reset ─────────────────────────────────────────────────────────
# How long the forgot-password reset link remains valid (seconds).
# Default: 86400 = 24 hours. Matches the copy shown in the email template.
# Change the template copy too if you adjust this value.
# PASSWORD_RESET_TIMEOUT=86400


# ── Database ───────────────────────────────────────────────────────────────
# The project currently uses SQLite (db.sqlite3) — no variable needed.
#
# When you switch to MariaDB / PostgreSQL for production, uncomment the
# relevant block below and update settings.py DATABASES accordingly.
#
# MariaDB / MySQL:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=hirepath_db
# DB_USER=sulabh
# DB_PASSWORD=3120
# DB_HOST=localhost
# DB_PORT=3306
#
# PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=hirepath_db
# DB_USER=sulabh
# DB_PASSWORD=3120
# DB_HOST=localhost
# DB_PORT=5432
#
# Docker MariaDB (matches your original commented block):
# DB_HOST=mariadb
# MARIADB_ROOT_PASSWORD=3120